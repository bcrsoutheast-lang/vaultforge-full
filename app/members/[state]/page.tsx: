"use client";

import { useEffect, useState } from "react";

export default function StateMembers({ params }: { params: { state: string } }) {
  const state = params.state.toUpperCase();
  const [members, setMembers] = useState<any[]>([]);

  useEffect(() => {
    const stored = localStorage.getItem("vaultforge_members");
    const allMembers = stored? JSON.parse(stored) : [];
    setMembers(allMembers.filter((m:any) => m.based_state === state));
  }, [state]);

  return (
    <main style={{minHeight:"100vh",background:"#05070d",color:"#fff",padding:16}}>
      <div style={{maxWidth:1200,margin:"0 auto"}}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16}}>
          <h1 style={{color:"#FFD700",fontWeight:900}}>{state} MEMBERS</h1>
          <a href="/members" style={{color:"#FFD700"}}>Back to States</a>
        </div>

        {members.length === 0? (
          <div style={{opacity:0.7}}>No members from {state} yet.</div>
        ) : (
          <div style={{display:"grid",gap:12}}>
            {members.map((m:any) => (
              <div key={m.email} style={{border:"1px solid #222",borderRadius:12,padding:16}}>
                <div style={{fontWeight:900}}>{m.name}</div>
                <div style={{opacity:0.7,fontSize:12}}>{m.email}</div>
                <div style={{opacity:0.7,fontSize:12}}>Serves: {m.states_served?.join(", ")}</div>
              </div>
            ))}
          </div>
        )}
      </div>
    </main>
  );
}
