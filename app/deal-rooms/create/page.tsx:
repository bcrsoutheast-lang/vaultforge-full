"use client";

import { useState } from "react";

const STATES = ["GA", "FL", "TN", "AL", "NC", "SC", "TX"];

export default function CreateDeal() {
  const [title, setTitle] = useState("");
  const [state, setState] = useState("GA");
  const [description, setDescription] = useState("");

  function saveDeal() {
    if (!title.trim()) return alert("Enter a deal title");

    const email = localStorage.getItem("vaultforge_current_email") || "unknown";
    const stored = localStorage.getItem("vaultforge_deals");
    const deals = stored? JSON.parse(stored) : [];

    deals.push({
      title,
      state,
      description,
      postedBy: email,
      createdAt: Date.now()
    });

    localStorage.setItem("vaultforge_deals", JSON.stringify(deals));
    alert("Deal posted!");
    window.location.href = `/deal-rooms/${state.toLowerCase()}`;
  }

  return (
    <main style={{minHeight:"100vh",background:"#05070d",color:"#fff",padding:16}}>
      <div style={{maxWidth:600,margin:"0 auto"}}>
        <h1 style={{color:"#FFD700",fontWeight:900,marginBottom:16}}>POST DEAL OPPORTUNITY</h1>

        <label style={{display:"block",marginBottom:8}}>Deal Title</label>
        <input
          value={title}
          onChange={e=>setTitle(e.target.value)}
          placeholder="Ex: 50-unit multifamily off-market"
          style={{width:"100%",padding:12,marginBottom:16,borderRadius:8,background:"#0a0f1a",border:"1px solid #222",color:"#fff"}}
        />

        <label style={{display:"block",marginBottom:8}}>State</label>
        <select
          value={state}
          onChange={e=>setState(e.target.value)}
          style={{width:"100%",padding:12,marginBottom:16,borderRadius:8,background:"#0a0f1a",border:"1px solid #222",color:"#fff"}}
        >
          {STATES.map(s => <option key={s} value={s}>{s}</option>)}
        </select>

        <label style={{display:"block",marginBottom:8}}>Description</label>
        <textarea
          value={description}
          onChange={e=>setDescription(e.target.value)}
          placeholder="Deal details, terms, what you're looking for..."
          rows={4}
          style={{width:"100%",padding:12,marginBottom:24,borderRadius:8,background:"#0a0f1a",border:"1px solid #222",color:"#fff"}}
        />

        <button
          onClick={saveDeal}
          style={{padding:"14px 22px",borderRadius:999,fontWeight:900,background:"#FFD700",color:"#000",width:"100%"}}
        >
          Post Deal
        </button>

        <a href="/deal-rooms" style={{display:"block",marginTop:16,textAlign:"center",color:"#FFD700"}}>Cancel</a>
      </div>
    </main>
  );
}
