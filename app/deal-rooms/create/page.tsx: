use client";

import { useState, useEffect } from "react";

const STATES = ["GA", "FL", "TN", "AL", "NC", "SC", "TX"];
const PROPERTY_TYPES = ["Single Family", "Multi-Family 2-4", "Multi-Family 5+", "Commercial Retail", "Commercial Office", "Industrial", "Land", "Mixed Use"];
const DEAL_TYPES = ["Wholesale", "Fix & Flip", "Buy & Hold", "Subject-To", "Seller Finance", "Lease Option", "Note Deal", "Joint Venture"];
const EXIT_STRATEGIES = ["Assign Contract", "Double Close", "Wholetail", "Rehab & Retail", "Rent & Hold", "Creative Finance"];
const RATINGS = ["A+ Deal", "B+ Solid", "C Needs Work", "D+ Pass"];

export default function CreateDealVaultForge() {
  const [form, setForm] = useState({
    title: "",
    state: "",
    propertyType: "",
    dealType: "",
    exitStrategy: "",
    askPrice: "",
    arv: "",
    repairEst: "",
    address: "",
    description: "",
    photos: [] as string[],
    vaultForgeRating: ""
  });

  const [profile, setProfile] = useState<any>({});
  const [aiRating, setAiRating] = useState<any>(null);
  const [analyzing, setAnalyzing] = useState(false);

  useEffect(() => {
    const email = localStorage.getItem("vaultforge_current_email") || "";
    const profiles = JSON.parse(localStorage.getItem("vaultforge_profiles") || "{}");
    setProfile(profiles[email] || { email });
  }, []);

  function handlePhotoUpload(e: any) {
    const files = Array.from(e.target.files) as File[];
    if (form.photos.length + files.length > 10) {
      alert("Max 10 photos");
      return;
    }
    
    files.forEach(file => {
      const reader = new FileReader();
      reader.onload = (event) => {
        setForm(prev => ({
        ...prev,
          photos: [...prev.photos, event.target?.result as string]
        }));
      };
      reader.readAsDataURL(file);
    });
  }

  function removePhoto(index: number) {
    setForm(prev => ({
    ...prev,
      photos: prev.photos.filter((_, i) => i!== index)
    }));
  }

  function runVaultForgeRating() {
    if (!form.askPrice ||!form.arv ||!form.repairEst ||!form.dealType) {
      alert("Enter Ask Price, ARV, Repair Est, and Deal Type first");
      return;
    }

    setAnalyzing(true);
    
    setTimeout(() => {
      const ask = parseFloat(form.askPrice.replace(/[^0-9.]/g, ''));
      const arv = parseFloat(form.arv.replace(/[^0-9.]/g, ''));
      const repair = parseFloat(form.repairEst.replace(/[^0-9.]/g, ''));
      
      const totalCost = ask + repair;
      const profit = arv - totalCost;
      const roi = (profit / totalCost * 100).toFixed(1);
      const margin = (profit / arv * 100).toFixed(1);
      
      let rating = "";
      let feedback = "";
      
      if (parseFloat(margin) > 25 && parseFloat(roi) > 30) {
        rating = "A+ Deal";
        feedback = "Strong margins. Green light. This is a VaultForge certified deal.";
      } else if (parseFloat(margin) > 15 && parseFloat(roi) > 20) {
        rating = "B+ Solid";
        feedback = "Good fundamentals. Verify repair scope. Worth pursuing.";
      } else if (parseFloat(margin) > 8) {
        rating = "C Needs Work";
        feedback = "Thin margins. Negotiate price down or pass. High risk.";
      } else {
        rating = "D+ Pass";
        feedback = "No profit. Deal killer. Move to next opportunity.";
      }

      const analysis = {
        profit: profit.toLocaleString(),
        roi: roi + "%",
        margin: margin + "%",
        rating,
        feedback,
        nextStep: profit > 0? "Run comps → Lock contract → Find buyer" : "Pass or renegotiate"
      };
      
      setAiRating(analysis);
      setForm(prev => ({...prev, vaultForgeRating: rating}));
      setAnalyzing(false);
    }, 1200);
  }

  function handleSubmit() {
    const currentEmail = localStorage.getItem("vaultforge_current_email") || "";
    if (!currentEmail) {
      alert("Login required");
      return;
    }

    if (!form.title ||!form.state ||!form.dealType ||!form.askPrice) {
      alert("Title, State, Deal Type, and Ask Price required");
      return;
    }

    const stored = localStorage.getItem("vaultforge_deals");
    const deals = stored? JSON.parse(stored) : [];
    
    const newDeal = {
      id: Date.now(),
    ...form,
      postedBy: currentEmail,
      posterProfile: profile,
      status: "active",
      timestamp: Date.now(),
      savedBy: [],
      archivedBy: [],
      vaultForgeAnalysis: aiRating
    };

    deals.push(newDeal);
    localStorage.setItem("vaultforge_deals", JSON.stringify(deals));
    alert("Deal posted with VaultForge rating!");
    window.location.href = `/deal-rooms/${form.state}`;
  }

  return (
    <main style={{minHeight:"100vh",background:"#05070d",color:"#fff",padding:16}}>
      <div style={{maxWidth:800,margin:"0 auto"}}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:24}}>
          <div>
            <h1 style={{color:"#FFD700",fontWeight:900,fontSize:28}}>VAULTFORGE DEAL INTAKE</h1>
            <div style={{fontSize:12,opacity:0.7}}>Fast. Clean. Profitable.</div>
          </div>
          <a href="/deal-rooms" style={{color:"#FFD700"}}>Cancel</a>
        </div>

        {/* Profile Auto-Attached */}
        <div style={{border:"1px solid #FFD700",borderRadius:12,padding:12,background:"#0a0f1a",marginBottom:16,display:"flex",alignItems:"center",gap:12}}>
          {profile.photo? (
            <img src={profile.photo} style={{width:40,height:40,borderRadius:"50%",objectFit:"cover"}} />
          ) : (
            <div style={{width:40,height:40,borderRadius:"50%",background:"#222",display:"flex",alignItems:"center",justifyContent:"center"}}>👤</div>
          )}
          <div>
            <div style={{fontWeight:900,fontSize:14}}>{profile.email}</div>
            <div style={{fontSize:11,opacity:0.7}}>Based: {profile.based_state || "N/A"} | Serving: {(profile.states_served || []).join(", ")}</div>
          </div>
        </div>

        <div style={{border:"1px solid #222",borderRadius:12,padding:24,background:"#0a0f1a",marginBottom:16}}>
          <div style={{fontWeight:900,marginBottom:16,color:"#FFD700"}}>DEAL BASICS</div>
          
          <div style={{marginBottom:16}}>
            <label style={{display:"block",marginBottom:8,fontWeight:900}}>Deal Title *</label>
            <input 
              value={form.title}
              onChange={e=>setForm({...form,title:e.target.value})}
              placeholder="3BR/2BA SFH - Assignment"
              style={{width:"100%",padding:12,borderRadius:8,background:"#05070d",border:"1px solid #222",color:"#fff"}}
            />
          </div>

          <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(150px,1fr))",gap:12,marginBottom:16}}>
            <div>
              <label style={{display:"block",marginBottom:8,fontWeight:900,fontSize:12}}>State *</label>
              <select value={form.state} onChange={e=>setForm({...form,state:e.target.value})} style={{width:"100%",padding:10,borderRadius:8,background:"#05070d",border:"1px solid #222",color:"#fff",fontSize:14}}>
                <option value="">Select</option>
                {STATES.map(s => <option key={s} value={s}>{s}</option>)}
              </select>
            </div>
            <div>
              <label style={{display:"block",marginBottom:8,fontWeight:900,fontSize:12}}>Property *</label>
              <select value={form.propertyType} onChange={e=>setForm({...form,propertyType:e.target.value})} style={{width:"100%",padding:10,borderRadius:8,background:"#05070d",border:"1px solid #222",color:"#fff",fontSize:14}}>
                <option value="">Select</option>
                {PROPERTY_TYPES.map(t => <option key={t} value={t}>{t}</option>)}
              </select>
            </div>
            <div>
              <label style={{display:"block",marginBottom:8,fontWeight:900,fontSize:12}}>Deal Type *</label>
              <select value={form.dealType} onChange={e=>setForm({...form,dealType:e.target.value})} style={{width:"100%",padding:10,borderRadius:8,background:"#05070d",border:"1px solid #222",color:"#fff",fontSize:14}}>
                <option value="">Select</option>
                {DEAL_TYPES.map(d => <option key={d} value={d}>{d}</option>)}
              </select>
            </div>
          </div>

          <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(150px,1fr))",gap:12,marginBottom:16}}>
            <div>
              <label style={{display:"block",marginBottom:8,fontWeight:900,fontSize:12}}>Ask Price *</label>
              <input 
                value={form.askPrice}
                onChange={e=>setForm({...form,askPrice:e.target.value})}
                placeholder="$150,000"
                style={{width:"100%",padding:10,borderRadius:8,background:"#05070d",border:"1px solid #222",color:"#fff",fontSize:14}}
              />
            </div>
            <div>
              <label style={{display:"block",marginBottom:8,fontWeight:900,fontSize:12}}>ARV</label>
              <input 
                value={form.arv}
                onChange={e=>setForm({...form,arv:e.target.value})}
                placeholder="$220,000"
                style={{width:"100%",padding:10,borderRadius:8,background:"#05070d",border:"1px solid #222",color:"#fff",fontSize:14}}
              />
            </div>
            <div>
              <label style={{display:"block",marginBottom:8,fontWeight:900,fontSize:12}}>Repair Est</label>
              <input 
                value={form.repairEst}
                onChange={e=>setForm({...form,repairEst:e.target.value})}
                placeholder="$25,000"
                style={{width:"100%",padding:10,borderRadius:8,background:"#05070d",border:"1px solid #222",color:"#fff",fontSize:14}}
              />
            </div>
          </div>

          <div style={{marginBottom:16}}>
            <label style={{display:"block",marginBottom:8,fontWeight:900,fontSize:12}}>Exit Strategy</label>
            <select value={form.exitStrategy} onChange={e=>setForm({...form,exitStrategy:e.target.value})} style={{width:"100%",padding:10,borderRadius:8,background:"#05070d",border:"1px solid #222",color:"#fff",fontSize:14}}>
              <option value="">Select</option>
              {EXIT_STRATEGIES.map(e => <option key={e} value={e}>{e}</option>)}
            </select>
          </div>

          <div style={{marginBottom:16}}>
            <label style={{display:"block",marginBottom:8,fontWeight:900}}>Address/City</label>
            <input 
              value={form.address}
              onChange={e=>setForm({...form,address:e.target.value})}
              placeholder="123 Main St, Atlanta, GA"
              style={{width:"100%",padding:12,borderRadius:8,background:"#05070d",border:"1px solid #222",color:"#fff"}}
            />
          </div>

          <div style={{marginBottom:16}}>
            <label style={{display:"block",marginBottom:8,fontWeight:900}}>Quick Notes</label>
            <textarea 
              value={form.description}
              onChange={e=>setForm({...form,description:e.target.value})}
              placeholder="Motivated seller, vacant, needs roof..."
              rows={3}
              style={{width:"100%",padding:12,borderRadius:8,background:"#05070d",border:"1px solid #222",color:"#fff",resize:"none"}}
            />
          </div>

          {/* Photo Upload */}
          <div style={{marginBottom:16}}>
            <label style={{display:"block",marginBottom:8,fontWeight:900}}>Photos ({form.photos.length}/10)</label>
            <input 
              type="file" 
              accept="image/*" 
              multiple
              onChange={handlePhotoUpload}
              style={{marginBottom:12,fontSize:12}}
            />
            <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(80px,1fr))",gap:8}}>
              {form.photos.map((photo, idx) => (
                <div key={idx} style={{position:"relative"}}>
                  <img src={photo} style={{width:"100%",height:80,objectFit:"cover",borderRadius:8}} />
                  <button 
                    onClick={()=>removePhoto(idx)}
                    style={{position:"absolute",top:4,right:4,width:20,height:20,borderRadius:"50%",background:"#ff4444",color:"#fff",fontSize:12,border:"none"}}
                  >×</button>
                </div>
              ))}
            </div>
          </div>

          {/* VaultForge AI Rating Button */}
          <button
            onClick={runVaultForgeRating}
            disabled={analyzing}
            style={{
              width:"100%",
              padding:"12px",
              borderRadius:8,
              fontWeight:900,
              background: analyzing? "#333" : "linear-gradient(90deg,#FFD700,#FFA500)",
              color:"#000",
              marginBottom:16,
              border:"none"
            }}
          >
            {analyzing? "Analyzing..." : "⚡ VAULTFORGE DEAL RATING"}
          </button>

          {/* AI Results */}
          {aiRating && (
            <div style={{border:`2px solid ${aiRating.rating.includes("A")? "#00ff00" : aiRating.rating.includes("B")? "#FFD700" : "#ff4444"}`,borderRadius:12,padding:16,background:"#0a0f1a",marginBottom:16}}>
              <div style={{fontWeight:900,marginBottom:12,color:"#FFD700",fontSize:18}}>{aiRating.rating}</div>
              <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:8,marginBottom:12}}>
                <div style={{textAlign:"center"}}>
                  <div style={{fontSize:11,opacity:0.7}}>Profit</div>
                  <div style={{fontWeight:900,color:"#00ff00"}}>${aiRating.profit}</div>
                </div>
                <div style={{textAlign:"center"}}>
                  <div style={{fontSize:11,opacity:0.7}}>ROI</div>
                  <div style={{fontWeight:900,color:"#FFD700"}}>{aiRating.roi}</div>
                </div>
                <div style={{textAlign:"center"}}>
                  <div style={{fontSize:11,opacity:0.7}}>Margin</div>
                  <div style={{fontWeight:900,color:"#FFD700"}}>{aiRating.margin}</div>
                </div>
              </div>
              <div style={{fontSize:12,marginBottom:8}}><strong>Feedback:</strong> {aiRating.feedback}</div>
              <div style={{fontSize:12}}border:"none"
            }}
          >
            {analyzing? "Analyzing..." : "⚡ VAULTFORGE DEAL RATING"}
          </button>

          {/* AI Results */}
          {aiRating && (
            <div style={{border:`2px solid ${aiRating.rating.includes("A")? "#00ff00" : aiRating.rating.includes("B")? "#FFD700" : "#ff4444"}`,borderRadius:12,padding:16,background:"#0a0f1a",marginBottom:16}}>
              <div style={{fontWeight:900,marginBottom:12,color:"#FFD700",fontSize:18}}>{aiRating.rating}</div>
              <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:8,marginBottom:12}}>
                <div style={{textAlign:"center"}}>
                  <div style={{fontSize:11,opacity:0.7}}>Profit</div>
                  <div style={{fontWeight:900,color:"#00ff00"}}>${aiRating.profit}</div>
                </div>
                <div style={{textAlign:"center"}}>
                  <div style={{fontSize:11,opacity:0.7}}>ROI</div>
                  <div style={{fontWeight:900,color:"#FFD700"}}>{aiRating.roi}</div>
                </div>
                <div style={{textAlign:"center"}}>
                  <div style={{fontSize:11,opacity:0.7}}>Margin</div>
                  <div style={{fontWeight:900,color:"#FFD700"}}>{aiRating.margin}</div>
                </div>
              </div>
              <div style={{fontSize:12,marginBottom:8}}><strong>Feedback:</strong> {aiRating.feedback}</div>
              <div style={{fontSize:12}}><strong>Next Step:</strong> {aiRating.nextStep}</div>
            </div>
          )}

          <button
            onClick={handleSubmit}
            style={{
              width:"100%",
              padding:"14px 22px",
              borderRadius:999,
              fontWeight:900,
              background:"#FFD700",
              color:"#000"
            }}
          >
            Post Deal to VaultForge
          </button>
        </div>
      </div>
    </main>
  );
}
